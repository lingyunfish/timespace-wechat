.profile-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.profile-header { position: relative; }
.header-bg-gradient {
  position: absolute; top: 0; left: 0; right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
}
.profile-card {
  position: relative;
  margin: 0 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: 30rpx;
}
.user-main {
  display: flex; align-items: center;
  margin-bottom: 30rpx;
}
.user-avatar-large {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}
.user-detail { flex: 1; margin-left: 24rpx; }
.user-nickname {
  font-size: 38rpx; font-weight: 700; color: #fff; display: block;
}
.user-level {
  display: flex; align-items: center; margin-top: 8rpx;
}
.level-badge {
  background: linear-gradient(135deg, #f9ca24, #f0932b);
  color: #fff; font-size: 20rpx;
  padding: 2rpx 12rpx; border-radius: 10rpx;
  margin-right: 10rpx; font-weight: 600;
}
.level-title {
  font-size: 24rpx; color: rgba(255, 255, 255, 0.7);
}
.vip-badge {
  background: linear-gradient(135deg, #f9ca24, #e17055);
  padding: 8rpx 20rpx; border-radius: 20rpx;
  color: #fff; font-size: 22rpx; font-weight: 600;
}

.login-prompt {
  display: flex; flex-direction: column; align-items: center;
  padding: 30rpx 0;
}
.login-text {
  font-size: 30rpx; color: #fff; margin-top: 16rpx;
}

.user-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 0;
  backdrop-filter: blur(10px);
}
.stat-block {
  flex: 1; text-align: center;
}
.stat-num-large {
  font-size: 36rpx; font-weight: 700; color: #fff; display: block;
}
.stat-label-small {
  font-size: 22rpx; color: rgba(255, 255, 255, 0.6); display: block; margin-top: 4rpx;
}

/* 卡片 */
.section-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx; font-weight: 600; color: #1a1a2e;
}
.section-more {
  font-size: 24rpx; color: #6c5ce7;
}

/* 成就 */
.achievement-scroll {
  white-space: nowrap;
}
.achievement-item {
  display: inline-flex; flex-direction: column;
  align-items: center; justify-content: center;
  width: 140rpx; height: 140rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
}
.achievement-item.unlocked {
  background: linear-gradient(135deg, #f0efff, #e8e6ff);
}
.achievement-item.locked {
  background: #f5f5f5; opacity: 0.6;
}
.achievement-emoji {
  font-size: 40rpx; margin-bottom: 6rpx;
}
.achievement-name {
  font-size: 20rpx; color: #666;
  white-space: normal; text-align: center;
  line-height: 1.2;
}
.achievement-progress {
  font-size: 18rpx; color: #999; margin-top: 4rpx;
}

/* 菜单 */
.menu-item {
  display: flex; align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text {
  flex: 1; font-size: 28rpx; color: #333;
}
.menu-arrow {
  font-size: 32rpx; color: #ccc;
}
.menu-tag {
  background: #f0efff;
  color: #6c5ce7;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  margin-right: 10rpx;
}
