.place-page {
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: #f5f5f5;
}

/* 头部 */
.place-header {
  position: relative;
  overflow: hidden;
}
.header-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}
.header-content {
  position: relative; padding: 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 88rpx);
}
.place-name-row {
  display: flex; align-items: center; margin-bottom: 10rpx;
}
.place-name {
  font-size: 42rpx; font-weight: 700; color: #fff;
}
.official-badge {
  background: linear-gradient(135deg, #f9ca24, #f0932b);
  color: #fff; font-size: 20rpx;
  padding: 4rpx 14rpx; border-radius: 12rpx;
  margin-left: 16rpx;
}
.place-desc {
  font-size: 26rpx; color: rgba(255, 255, 255, 0.7);
  margin-bottom: 24rpx;
}
.place-stats {
  display: flex; align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx; padding: 20rpx 0;
}
.stat-item {
  flex: 1; text-align: center;
}
.stat-num {
  font-size: 36rpx; font-weight: 700; color: #fff; display: block;
}
.stat-label {
  font-size: 22rpx; color: rgba(255, 255, 255, 0.6); display: block; margin-top: 4rpx;
}
.stat-divider {
  width: 1rpx; height: 50rpx; background: rgba(255, 255, 255, 0.15);
}

.place-lock, .place-unlock {
  display: flex; align-items: center;
  margin-top: 20rpx; padding: 16rpx 20rpx;
  border-radius: 12rpx;
}
.place-lock {
  background: rgba(255, 107, 107, 0.2);
}
.place-unlock {
  background: rgba(0, 255, 136, 0.15);
}
.lock-icon, .unlock-icon {
  font-size: 30rpx; margin-right: 10rpx;
}
.lock-text {
  font-size: 24rpx; color: #ff6b6b;
}
.unlock-text {
  font-size: 24rpx; color: #00ff88;
}

/* 筛选 */
.filter-bar {
  display: flex; align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky; top: 0; z-index: 10;
}
.filter-item {
  font-size: 26rpx; color: #999;
  padding: 8rpx 20rpx; margin-right: 16rpx;
  border-radius: 20rpx;
}
.filter-item.active {
  color: #6c5ce7; background: #f0efff; font-weight: 500;
}
.filter-toggle {
  margin-left: auto;
  font-size: 24rpx; color: #6c5ce7;
  padding: 8rpx 16rpx;
  border: 1rpx solid #e0defe;
  border-radius: 20rpx;
}

.geo-tip {
  display: flex; align-items: center;
  padding: 16rpx 24rpx;
  background: #fff8e1;
  font-size: 24rpx; color: #f39c12;
}
.geo-tip-icon { margin-right: 8rpx; }

/* 网格 */
.photo-grid {
  display: flex; flex-wrap: wrap;
  padding: 8rpx;
}
.grid-item {
  width: calc(50% - 8rpx); margin: 4rpx;
  border-radius: 12rpx; overflow: hidden;
  position: relative; background: #fff;
}
.grid-photo {
  width: 100%; height: 340rpx;
}
.grid-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 30rpx 12rpx 12rpx;
  display: flex; justify-content: space-between; align-items: flex-end;
}
.grid-user {
  display: flex; align-items: center;
}
.grid-avatar {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  margin-right: 8rpx; border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.grid-username {
  font-size: 22rpx; color: #fff;
}
.grid-likes {
  font-size: 22rpx; color: #fff;
}
.grid-lock {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex; justify-content: center; align-items: center;
  backdrop-filter: blur(8px);
}
.grid-lock-icon { font-size: 48rpx; }

/* 瀑布流 */
.photo-waterfall {
  display: flex; padding: 8rpx;
}
.waterfall-col {
  flex: 1; padding: 0 4rpx;
}
.waterfall-item {
  background: #fff; border-radius: 12rpx;
  overflow: hidden; margin-bottom: 8rpx;
  position: relative;
}
.waterfall-photo {
  width: 100%;
}
.waterfall-info {
  padding: 12rpx;
}
.waterfall-user-row {
  display: flex; align-items: center; margin-bottom: 8rpx;
}
.waterfall-avatar {
  width: 32rpx; height: 32rpx; border-radius: 50%; margin-right: 8rpx;
}
.waterfall-username {
  font-size: 22rpx; color: #666;
}
.waterfall-desc {
  font-size: 24rpx; color: #333;
  display: -webkit-box; -webkit-line-clamp: 2;
  -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 8rpx;
}
.waterfall-meta {
  display: flex; justify-content: space-between;
}
.waterfall-time {
  font-size: 20rpx; color: #ccc;
}
.waterfall-likes {
  font-size: 20rpx; color: #ff6b6b;
}

/* 加载 */
.load-more {
  text-align: center; padding: 30rpx;
}
.load-more-text { font-size: 24rpx; color: #ccc; }

/* 空状态 */
.empty-state {
  padding: 100rpx 0; text-align: center;
}
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; color: #999; display: block; }
.empty-hint { font-size: 24rpx; color: #ccc; display: block; margin-top: 8rpx; }

.bottom-publish {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}
