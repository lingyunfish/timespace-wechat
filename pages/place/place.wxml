<view class="place-page">
  <!-- 顶部地点信息 -->
  <view class="place-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="place-info">
        <view class="place-name-row">
          <text class="place-name">{{place.name}}</text>
          <view class="official-badge" wx:if="{{place.is_official}}">官方认证</view>
        </view>
        <text class="place-desc">{{place.description || '这里有独特的记忆等你发现'}}</text>
        <view class="place-stats">
          <view class="stat-item">
            <text class="stat-num">{{place.photo_count || 0}}</text>
            <text class="stat-label">照片</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-num">{{place.visitor_count || 0}}</text>
            <text class="stat-label">访客</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-num">{{place.like_count || 0}}</text>
            <text class="stat-label">点赞</text>
          </view>
        </view>
      </view>
      <view class="place-lock" wx:if="{{!isNearby}}">
        <text class="lock-icon">🔒</text>
        <text class="lock-text">距离 {{distanceText}}，需到达附近50m内解锁</text>
      </view>
      <view class="place-unlock" wx:if="{{isNearby}}">
        <text class="unlock-icon">🔓</text>
        <text class="unlock-text">已解锁，你正在此记忆点附近</text>
      </view>
    </view>
  </view>

  <!-- 排序筛选器 -->
  <view class="filter-bar">
    <view
      class="filter-item {{sortType === 'latest' ? 'active' : ''}}"
      bindtap="switchSort"
      data-type="latest"
    >最新发布</view>
    <view
      class="filter-item {{sortType === 'popular' ? 'active' : ''}}"
      bindtap="switchSort"
      data-type="popular"
    >最多点赞</view>
    <view
      class="filter-item {{sortType === 'oldest' ? 'active' : ''}}"
      bindtap="switchSort"
      data-type="oldest"
    >时间倒序</view>
    <view class="filter-toggle" bindtap="toggleLayout">
      <text>{{isGrid ? '瀑布流' : '网格'}}</text>
    </view>
  </view>

  <!-- 评论地域限制提示 -->
  <view class="geo-tip" wx:if="{{!isNearby}}">
    <text class="geo-tip-icon">📍</text>
    <text>部分内容和互动仅限在此地点附近可用</text>
  </view>

  <!-- 照片列表 - 网格模式 -->
  <view class="photo-grid" wx:if="{{isGrid}}">
    <view
      class="grid-item"
      wx:for="{{photos}}"
      wx:key="id"
      bindtap="viewPhoto"
      data-photo="{{item}}"
      data-index="{{index}}"
    >
      <image
        src="{{item.thumbnail_url || item.image_url}}"
        mode="aspectFill"
        class="grid-photo"
        lazy-load
      />
      <view class="grid-overlay">
        <view class="grid-user">
          <image class="grid-avatar" src="{{item.user_avatar || '/images/tab-profile.png'}}" />
          <text class="grid-username">{{item.user_name || '匿名'}}</text>
        </view>
        <view class="grid-meta">
          <text class="grid-likes">♥ {{item.like_count || 0}}</text>
        </view>
      </view>
      <view class="grid-lock" wx:if="{{!isNearby && !item.is_preview}}">
        <text class="grid-lock-icon">🔒</text>
      </view>
    </view>
  </view>

  <!-- 照片列表 - 瀑布流模式 -->
  <view class="photo-waterfall" wx:else>
    <view class="waterfall-col waterfall-left">
      <view
        class="waterfall-item"
        wx:for="{{leftPhotos}}"
        wx:key="id"
        bindtap="viewPhoto"
        data-photo="{{item}}"
        data-index="{{item._index}}"
      >
        <image
          src="{{item.thumbnail_url || item.image_url}}"
          mode="widthFix"
          class="waterfall-photo"
          lazy-load
        />
        <view class="waterfall-info">
          <view class="waterfall-user-row">
            <image class="waterfall-avatar" src="{{item.user_avatar || '/images/tab-profile.png'}}" />
            <text class="waterfall-username">{{item.user_name || '匿名'}}</text>
          </view>
          <text class="waterfall-desc" wx:if="{{item.description}}">{{item.description}}</text>
          <view class="waterfall-meta">
            <text class="waterfall-time">{{item.time_text}}</text>
            <text class="waterfall-likes">♥ {{item.like_count || 0}}</text>
          </view>
        </view>
        <view class="grid-lock" wx:if="{{!isNearby && !item.is_preview}}">
          <text class="grid-lock-icon">🔒</text>
        </view>
      </view>
    </view>
    <view class="waterfall-col waterfall-right">
      <view
        class="waterfall-item"
        wx:for="{{rightPhotos}}"
        wx:key="id"
        bindtap="viewPhoto"
        data-photo="{{item}}"
        data-index="{{item._index}}"
      >
        <image
          src="{{item.thumbnail_url || item.image_url}}"
          mode="widthFix"
          class="waterfall-photo"
          lazy-load
        />
        <view class="waterfall-info">
          <view class="waterfall-user-row">
            <image class="waterfall-avatar" src="{{item.user_avatar || '/images/tab-profile.png'}}" />
            <text class="waterfall-username">{{item.user_name || '匿名'}}</text>
          </view>
          <text class="waterfall-desc" wx:if="{{item.description}}">{{item.description}}</text>
          <view class="waterfall-meta">
            <text class="waterfall-time">{{item.time_text}}</text>
            <text class="waterfall-likes">♥ {{item.like_count || 0}}</text>
          </view>
        </view>
        <view class="grid-lock" wx:if="{{!isNearby && !item.is_preview}}">
          <text class="grid-lock-icon">🔒</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text class="load-more-text">{{loading ? '加载中...' : '上拉加载更多'}}</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && photos.length === 0}}">
    <text class="empty-icon">📷</text>
    <text class="empty-text">这里还没有记忆</text>
    <text class="empty-hint">成为第一个在此投递记忆的人吧！</text>
    <view class="btn-primary mt-30" bindtap="goPublish" wx:if="{{isNearby}}">投递记忆</view>
  </view>

  <!-- 底部发布按钮 -->
  <view class="bottom-publish" wx:if="{{isNearby && photos.length > 0}}">
    <view class="btn-primary" bindtap="goPublish">在此投递记忆</view>
  </view>
</view>
